# Jira webhook authentication
JIRA_WEBHOOK_SECRET=change-me-to-a-long-random-string

# OpenWA connection (use internal URL on same VPS when deployed)
OPENWA_BASE_URL=https://whatsapp.werevu.co.ke
OPENWA_API_KEY=owa_k1_your_api_key_here
OPENWA_SESSION_ID=your-session-uuid

# User email -> phone mapping file path
USER_MAP_PATH=config/user_map.json

# Server
HOST=127.0.0.1
PORT=6060
LOG_LEVEL=INFO

# Optional: retry failed OpenWA sends
OPENWA_MAX_RETRIES=2
OPENWA_RETRY_DELAY_SECONDS=1.0
